  entries:
  - specialNPCEntry: {fileID: 11400000, guid: 02d20fc08f1f5b94f869864a11e62c86, type: 2}
    panelText: "\u8FD9\u662F...\u771F\u5B9E\u4E16\u754C\uFF1F"
    storyText: "\u4E5F\u8BB8\u50CF\u7D20\u4EA4\u5927\u91CC\u7684\u89D2\u8272\u90FD\u662F\u901A\u8FC7\u67D0\u79CD\u9B54\u6CD5\u751F\u6210\u51FA\u6765\u7684\u5462"
  - specialNPCEntry: {fileID: 11400000, guid: 692ae473aaa97db4ab21d0c4517c90ce, type: 2}
    panelText: "\u5BFB\u627E\u5927\u56FD\u91CD\u5668 \u5E8F"
    storyText: "\u4E5F\u8BB8\u6211\u4EEC\u5E94\u8BE5\u5728\u56FE\u4E66\u9986\u5468\u56F4\u627E\u627E\u7EBF\u7D22\uFF0C\u8BF4\u4E0D\u5B9A\u6709\u80FD\u5E2E\u52A9\u4ED6\u524D\u5F80\u5927\u56FD\u91CD\u5668\u57FA\u5EFA\u73B0\u573A\u7684\u5730\u65B9\u5462"
  - specialNPCEntry: {fileID: 11400000, guid: 813263f5ea465e747adff77717183cbb, type: 2}
    panelText: "\u54FC"
    storyText: "\u770B\u8D77\u6765\u662F\u4E2A\u7EAF\u8DEF\u4EBA\uFF0C\u4E0D\u8FC7\u4ED6\u8BF4\u7684\u300A\u6211\u548C\u6211\u7684\u50CF\u7D20\u4EA4\u5927\u300B\u662F\u4E2A\u5565\u6E38\u620F\uFF0C\u54EA\u4E2A\u6E38\u620F\u5382\u505A\u7684"
  - specialNPCEntry: {fileID: 11400000, guid: 76c57cbc418efc14286eecbd435dbcaa, type: 2}
    panelText: "\u7231\u4F60\u8001\u51E0"
    storyText: "\u5927\u5B66\u65F6\u671F\u70ED\u60C5\u5F00\u6717\u3001\u5FC3\u6000\u7406\u60F3\uFF0C\u5BF9\u94C1\u8DEF\u4E8B\u4E1A\u5145\u6EE1\u8D64\u8BDA\uFF0C\u6DF1\u53D7\u5BFC\u5E08\u8D4F\u8BC6\uFF1B
      \u4F46\u662F\uFF0C\u4EFB\u5C0F\u660E\u6BD5\u4E1A\u540E\u88AB\u5FD9\u788C\u7684\u5DE5\u4F5C\u88F9\u631F\uFF0C\u53D8\u5F97\u5185\u655B\uFF0C\u751A\u81F3\u6709\u4E9B\u75B2\u60EB\u9EBB\u6728\uFF0C\u5185\u5FC3\u6697\u85CF\u7740\u5E74\u5C11\u65F6\u7684\u6FC0\u60C5\u4E0E\u7406\u60F3\uFF0C\u5374\u88AB\u751F\u8BA1\u7684\u5954\u6CE2\u63A9\u76D6\uFF0C\u5E38\u5E38\u5728\u6DF1\u591C\u7684\u5217\u8F66\u8C03\u5EA6\u5BA4\u91CC\u611F\u5230\u8FF7\u832B\uFF0C\u4E0D\u786E\u5B9A\u81EA\u5DF1\u575A\u6301\u8FD9\u4EFD\u5DE5\u4F5C\u7684\u610F\u4E49\u3002\u5C24\u5176\u662F\u5F53\u6625\u8FD0\u8FD9\u79CD\u7A81\u53D1\u60C5\u51B5\u6765\u4E34\u65F6\uFF0C\u4ED6\u66F4\u662F\u5FD9\u7684\u51E0\u5929\u90FD\u4E0D\u80FD\u597D\u597D\u5403\u996D\u3002"
  - specialNPCEntry: {fileID: 11400000, guid: 424cf818239339b489d3ae9f0e79542c, type: 2}
    panelText: "\u539F\u6765\u8FD9\u662F\u6536\u96C6\u6E38\u620F\u5417"
    storyText: "\u5BF9\u6E38\u620F\u91CC\u7684\u6536\u96C6\u4EFB\u52A1\u7279\u522B\u4E0A\u5FC3\uFF0C\u6821\u56ED\u91CC\u90A3\u4E9B\u4E0D\u8D77\u773C\u7684\u6253\u5361\u70B9\u6216\u8BB8\u85CF\u7740\u5B9D\u85CF\u5462"
  - specialNPCEntry: {fileID: 11400000, guid: c3e58d17cbfaf3c42811a36523f69f7c, type: 2}
    panelText: "\u559C\u6B22\u72EC\u81EA\u770B\u4E66\u7684\u5B66\u751F"
    storyText: "\u4E60\u60EF\u5728\u56FE\u4E66\u9986\u7684\u56FA\u5B9A\u4F4D\u7F6E\u5F85\u7740\u3002\u522B\u4EBA\u4E3B\u52A8\u642D\u8BDD\u65F6\u4ED6\u4F1A\u6709\u4E9B\u4E0D\u81EA\u5728\uFF0C\u4F46\u5E76\u4E0D\u6392\u65A5\u6709\u4EBA\u5750\u5728\u65C1\u8FB9\u3002"
  - specialNPCEntry: {fileID: 11400000, guid: 5d83e5ec65280ab4396f952a95ae2c8a, type: 2}
    panelText: "\u4E0A\u5B8C\u8BFE\u7684\u5B66\u751F 1"
    storyText: "\u5728\u4EA4\u5927\u4E0A\u5B66\u8BFE\u4E1A\u771F\u7684\u5F88\u591A\uFF0C\u4F46\u662F\u6211\u4EEC\u5728\u8BFE\u5802\u4E0A\u8FD8\u662F\u80FD\u6536\u83B7\u4E0D\u5C11\u77E5\u8BC6"
  - specialNPCEntry: {fileID: 11400000, guid: 1d9aed2fafb57514c8d8fe3cda24cc10, type: 2}
    panelText: "\u4E0A\u5B8C\u8BFE\u7684\u5B66\u751F 2"
    storyText: "\u4EA4\u5927\u7684\u8BFE\u7A0B\u5927\u90FD\u5B89\u6392\u7684\u975E\u5E38\u5408\u7406\uFF0C\u54EA\u6015\u662F\u201C\u6C34\u8BFE\u201D\u4ED6\u4E5F\u4ECE\u672A\u7F3A\u5E2D"
  - specialNPCEntry: {fileID: 11400000, guid: 1450c1dd4a982dd4fb23452736b272ff, type: 2}
    panelText: "\u70ED\u7231\u5B66\u4E60\u7684\u5B66\u751F"
    storyText: "\u4EE5\u63D0\u5347\u81EA\u6211\u4E3A\u4E50\u8DA3\u7684\u597D\u5B66\u4E4B\u4EBA\uFF0C\u540C\u5B66\u620F\u79F0\u4ED6\u4E3A\u5927\u54E5"
  - specialNPCEntry: {fileID: 11400000, guid: ab7f60776c66bae4ba7605efa10c56d2, type: 2}
    panelText: "\u4EA4\u5927\u7F8E\u98DF\u4E13\u5BB6\uFF08\u81EA\u5C01\uFF09"
    storyText: "\u7ACB\u5FD7\u5403\u904D\u4E16\u4E0A\u597D\u5403\u7684\uFF0C\u201C\u552F\u7F8E\u98DF\u548C\u68A6\u60F3\u4E0D\u53EF\u8F9C\u8D1F\uFF01\u201D\u4ED6\u8FD9\u6837\u6253\u5FC3\u5E95\u8BA4\u4E3A"
  - specialNPCEntry: {fileID: 11400000, guid: 072a115bf3f95b04e9ce08b23de6d90e, type: 2}
    panelText: "\u60F3...\u7761\u89C9"
    storyText: "\u5176\u5B9E\u53EA\u662F\u8282\u7EA6\u7741\u5927\u53CC\u773C\u7684\u80FD\u91CF\uFF0C\u6027\u683C\u6DE1\u6DE1\u7684\u5374\u4ECE\u4E0D\u7F3A\u5E2D\u597D\u670B\u53CB\u7684\u9080\u7EA6"
  - specialNPCEntry: {fileID: 11400000, guid: 16ff003a827eda24cb9a0168fd9098d5, type: 2}
    panelText: "\u4EA4\u9645\u80FD\u529B\u9887\u597D\u7684\u70ED\u60C5\u5206\u5B50"
    storyText: "\u5728\u4EA4\u5927\u8BA4\u8BC6\u4E86\u8BB8\u591A\u5F88\u597D\u7684\u4EBA\uFF0C\u4E0D\u8BBA\u662F\u5B66\u751F\u8FD8\u662F\u8001\u5E08\u90FD\u80FD\u642D\u5F97\u4E0A\u8BDD"
  - specialNPCEntry: {fileID: 11400000, guid: 936926664aa35aa40b971a071fd94b26, type: 2}
    panelText: "\u6821\u5E86\u8FDB\u884C\u65F6"
    storyText: "\u88AB\u6CE5\u4EA4\u8FD9\u4E9B\u5E74\u7FFB\u65B0\u7684\u8BBE\u5907\uFF0C\u76DB\u5927\u7684\u6821\u5E86\u6C1B\u56F4\u6253\u52A8\uFF0C\u611F\u6168\u81EA\u5DF1\u6765\u7684\u771F\u662F\u65F6\u5019"
  - specialNPCEntry: {fileID: 11400000, guid: d4acb56887789264b9e1e564ae17ec96, type: 2}
    panelText: "\u4E3A\u4E86\u68A6\u60F3 1"
    storyText: "2025\u7EA7\u571F\u6728\u5B66\u9662\u672C\u79D1\u65B0\u751F\u3002\u4ECE\u5C0F\u559C\u6B22\u642D\u79EF\u6728\u3001\u770B\u6865\u6881\uFF0C\u5411\u5F80\u628A\u56FE\u7EB8\u53D8\u6210\u73B0\u5B9E\u7684\u6210\u5C31\u611F\u3002\u9AD8\u8003\u5982\u613F\u8003\u4E0A\u571F\u6728\u5DE5\u7A0B\uFF0C\u5374\u88AB\u7236\u6BCD\u4EE5\u201C\u592A\u82E6\u3001\u5973\u751F\u96BE\u575A\u6301\u201D\u4E3A\u7531\u53CD\u590D\u529D\u8F6C\u4E13\u4E1A\u3002\u519B\u8BAD\u671F\u95F4\u5E38\u4E00\u4E2A\u4EBA\u7FFB\u770B\u4E13\u4E1A\u4E66\uFF0C\u8FF7\u832B\u4F46\u4E0D\u7518\u5FC3"
  - specialNPCEntry: {fileID: 11400000, guid: 52a5d564bd366cd4f917e222df624a7f, type: 2}
    panelText: "\u4E3A\u4E86\u68A6\u60F3 2"
    storyText: "25\u7EA7\u4EA4\u8FD0\u5B66\u9662\u672C\u79D1\u65B0\u751F\uFF0C\u7F57\u8D74\u5728\u5165\u5B66\u519B\u8BAD\u65F6\u8BA4\u8BC6\u7684\u670B\u53CB\u3002\u6027\u683C\u4E50\u89C2\u3001\u6709\u611F\u67D3\u529B\uFF0C\u548C\u7F57\u8D74\u5728\u519B\u8BAD\u62C9\u6B4C\u65F6\u8BA4\u8BC6\u3002\u76F8\u4FE1\u670B\u53CB\u7684\u9009\u62E9\uFF0C\u4E5F\u613F\u610F\u5728\u5173\u952E\u65F6\u523B\u575A\u5B9A\u5730\u63A8\u5979\u4E00\u628A"
  - specialNPCEntry: {fileID: 11400000, guid: fe9e23311865545429999247aad9e806, type: 2}
    panelText: "\u4E3A\u4E86\u68A6\u60F3 3"
    storyText: "24\u7EA7\u571F\u6728\u5DE5\u7A0B\u7814\u7A76\u751F\u517C25\u7EA7\u571F\u6728\u4E13\u4E1A\u672C\u79D1\u751F\u8F85\u5BFC\u5458\u3002\u6C89\u7A33\u3001\u4E25\u8C28\uFF0C\u5584\u4E8E\u7528\u6821\u53F2\u548C\u524D\u8F88\u4E8B\u8FF9\u5F15\u5BFC\u5B66\u751F\u601D\u8003\u3002\u4ECE\u4E0D\u8BF4\u6559\uFF0C\u800C\u662F\u7528\u95EE\u9898\u5E2E\u5B66\u751F\u770B\u6E05\u5185\u5FC3\u3002\u81EA\u5DF1\u4E5F\u6709\u7814\u7A76\u751F\u9636\u6BB5\u7684\u538B\u529B\uFF0C\u4F46\u9762\u5BF9\u5B66\u751F\u65F6\u6C38\u8FDC\u662F\u53EF\u9760\u7684\u6837\u5B50"
  - specialNPCEntry: {fileID: 11400000, guid: 8cfbe4cb9a89488449be7a08953072f1, type: 2}
    panelText: "\u699C\u6837\u7684\u529B\u91CF"
    storyText: "\u6BD5\u4E1A\u4E8E\u4EA4\u901A\u5927\u5B66\u5510\u5C71\u5DE5\u5B66\u9662\uFF08\u4ECA\u897F\u5357\u4EA4\u901A\u5927\u5B66\uFF09\u3002\u4E2D\u56FD\u7B2C\u4E00\u4F4D\u5973\u5DE5\u7A0B\u5E08\uFF0C\u4E5F\u662F\u5510\u5C71\u4EA4\u5927\uFF08\u897F\u5357\u4EA4\u5927\uFF09\u5386\u53F2\u4E0A\u9996\u4F4D\u5973\u5B66\u751F\u3002193
      3\u5E74\u4EE5\u4F18\u5F02\u6210\u7EE9\u6BD5\u4E1A\uFF0C\u540E\u4EFB\u4EA4\u901A\u90E8\u603B\u5DE5\u7A0B\u5E08\uFF0C\u4E3A\u4E2D\u56FD\u65E9\u671F\u94C1\u8DEF\u4E0E\u5DE5\u7A0B\u5EFA\u8BBE\u5960\u5B9A\u4E86\u4EBA\u624D\u57FA\u77F3"
  - specialNPCEntry: {fileID: 11400000, guid: f587e7b4906ea84438937e8a77319050, type: 2}
    panelText: "\u7AE2\u5B9E\u626C\u534E"
    storyText: "\u897F\u5357\u4EA4\u901A\u5927\u5B662023\u7EA7\u571F\u6728\u5DE5\u7A0B\u5B66\u9662\u672C\u79D1\u751F\uFF0C\u66FE\u4EFB\u73ED\u7EA7\u56E2\u652F\u4E66\uFF0C\u73B0\u4EFB\u6821\u53F2\u9986\u5B66\u751F\u8BB2\u89E3\u5458\u3002\u5979\u6E29\u548C\u5584\u826F\uFF0C\u505A\u4E8B\u8E0F\u5B9E\u80FD\u5E72\u3002\u6700\u559C\u6B22\u5728\u6821\u53F2\u9986\u95ED\u9986\u540E\uFF0C\u4E00\u4E2A\u4EBA\u8D70\u5230\u7AE2\u5B9E\u626C\u534E\u5899\u65C1\u7684\u996E\u6C34\u601D\u6E90\u7891\u524D\u5750\u4E00\u4F1A\u513F\u2014\u2014\u90A3\u662F\u5979\u5FC3\u4E2D\u6700\u5B89\u9759\u7684\u89D2\u843D"
  - specialNPCEntry: {fileID: 11400000, guid: 1332c92135fc3a24a8de034ce17f8307, type: 2}
    panelText: "\u8305\u4EE5\u5347\u7CBE\u795E 1"
    storyText: "2024\u7EA7\u672C\u79D1\xB7\u5EFA\u7B51\u5B66\xB7\u5927\u4E8C\u3002\u6015\u82E6\u6613\u62B1\u6028\uFF0C\u9996\u6B21\u6237\u5916\u6D4B\u7ED8\u5B9E\u4E60"
  - specialNPCEntry: {fileID: 11400000, guid: 5a0af1801c6909648972995f18b3fe2a, type: 2}
    panelText: "\u8305\u4EE5\u5347\u7CBE\u795E 2"
    storyText: "\u5EFA\u7B51\u5B66\u9662\xB7\u526F\u6559\u6388\u3002\u6E29\u548C\u4E25\u8C28\uFF0C\u9F13\u52B1\u5B66\u751F"
  - specialNPCEntry: {fileID: 11400000, guid: bbc0de6346ab6d6468a51bd20e947282, type: 2}
    panelText: "\u8305\u4EE5\u5347\u7CBE\u795E 3"
    storyText: "2023\u7EA7\u7855\u58EB\u7814\u7A76\u751F\xB7 \u5EFA\u7B51\u5B66\xB7\u52A9\u6559\u3002\u6C89\u7A33\u7EC6\u5FC3\uFF0C\u4E86\u89E3\u6821\u53F2"
  - specialNPCEntry: {fileID: 11400000, guid: 0d700098e5c88de439ca8940fa6c2d24, type: 2}
    panelText: "\u7ACB\u5FB7\u6811\u4EBA\uFF0C\u6559\u4E66\u80B2\u4EBA"
    storyText: "\u6750\u6599\u5B66\u9662\u9752\u5E74\u6559\u5E08\u3002\u52A1\u5B9E\u80FD\u5E72\uFF0C\u70ED\u7231\u6559\u5B66\uFF0C\u603B\u5728\u7422\u78E8\u5982\u4F55\u8BA9\u8BFE\u5802\u8282\u594F\u66F4\u52A0\u8212\u9002"
  - specialNPCEntry: {fileID: 11400000, guid: f4371cbbde4f60f4c8ac71b32282afdd, type: 2}
    panelText: "\u8305\u8001\u5343\u53E4"
    storyText: "1916\u5E74\u6BD5\u4E1A\u4E8E\u201C\u5510\u5C71\u5DE5\u4E1A\u4E13\u95E8\u5B66\u6821\u201D(\u897F\u5357\u4EA4\u5927)\uFF0C1917\u5E74\u83B7\u7F8E\u56FD\u5EB7\u4E43\u5C14\u5927\u5B66\u7855\u58EB\u5B66\u4F4D\uFF0C1919\u5E74\u83B7\u7F8E\u56FD\u5361\u8010\u57FA\u7406\u5DE5
      \u5B66\u9662\uFF08\u5148\u5361\u8010\u57FA\u6885\u9686\u5927\u5B66)\u535A\u58EB\u5B66\u4F4D\u3002
      \u4E3B\u6301\u8BBE\u8BA1\u52A0\u65BD\u5DE5\u4E2D\u56FD\u7B2C\u4E00\u5EA7\u73B0\u4EE3\u5316\u5927\u578B\u6865\u6881\uFF1A\u94B1\u5858\u6C5F\u5927\u6865(\u5F53\u65F6\u5916\u56FD\u5BF9\u4E2D\u56FD\u7684\u8BC4\u4EF7\u662F\uFF1A\u80FD\u5728\u94B1\u5858\u6C5F\u4E0A\u9020\u5927\u6865\u7684\u4E2D\u56FD\u5DE5\u7A0B\u5E08\u8FD8\u6CA1\u51FA\u4E16\u5462\uFF01\uFF09\u6210\u4E3A\u4E2D\u56FD\u94C1\u8DEF\u6865\u6881\u53F2\u4E0A\u7684\u4E00\u5757\u91CC\u7A0B\u7891\u8305\u4EE5\u5347\u5148\u751F\u66FE\u4EFB\u4EA4\u5927\u6821\u957F."
