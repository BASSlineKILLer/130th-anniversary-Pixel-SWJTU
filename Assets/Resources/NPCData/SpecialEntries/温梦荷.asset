  m_Script: {fileID: 11500000, guid: 4b6a0e83dfb259a4fa3adfa93dabfb9a, type: 3}
  m_Name: "\u6E29\u68A6\u8377"
  m_EditorClassIdentifier: 
  npcName: "\u6E29\u68A6\u8377"
  worldSprite: {fileID: 21300000, guid: f37fc9a5beee7be4a9521f1b92af8f37, type: 3}
  portrait: {fileID: 21300000, guid: f37fc9a5beee7be4a9521f1b92af8f37, type: 3}
  dialogueLines:
  - "\u4EA4\u5927\u8FD9\u4E48\u591A\u5E74\uFF0C\u8D70\u8FC7\u90A3\u4E48\u591A\u7684\u8DEF\u2026\u2026\u4ECE\u5510\u5C71\u5230\u5CE8\u7709\uFF0C\u518D\u5230\u6210\u90FD\uFF0C\u6BCF\u4E00\u4EE3\u4EBA\u90FD\u5728\u5F80\u524D\u8D70"
  - "\u6211\u4EEC\u8FD9\u4E00\u4EE3\u554A\uFF0C\u7AD9\u5728\u524D\u8F88\u94FA\u597D\u7684\u8DEF\u4E0A\uFF0C\u5176\u5B9E\u6700\u96BE\u7684\u4E0D\u662F\u201C\u600E\u4E48\u8D70\u201D\uFF0C\u800C\u662F\u201C\u8BB0\u5F97\u4E3A\u4EC0\u4E48\u8D70\u201D"
  - "\uFF08\u5979\u62AC\u5934\uFF0C\u76EE\u5149\u843D\u5728\u7891\u4E0A\u7684\u6821\u5FBD\u6D6E\u96D5\uFF0C\u8BED\u6C14\u6E29\u67D4\u800C\u575A\u5B9A\uFF09\r"
  - "\u6709\u65F6\u5019\u6211\u4E5F\u4F1A\u7D2F\uFF0C\u4F1A\u60F3\uFF1A\u4E00\u4E2A\u5C0F\u5C0F\u7684\u56E2\u652F\u4E66\uFF0C\u505A\u90A3\u4E48\u591A\u7410\u788E\u7684\u4E8B\uFF0C\u771F\u7684\u6709\u610F\u4E49\u5417\uFF1F"
  - "\u4F46\u6BCF\u6B21\u5750\u5728\u8FD9\u91CC\uFF0C\u770B\u5230\u7891\u4E0A\u8FD9\u51E0\u4E2A\u5B57\u2014\u2014\u201C\u996E\u6C34\u601D\u6E90\u201D\uFF0C\u5C31\u60F3\u8D77\u6731\u9896\u5353\u524D\u8F88\u5F53\u5E74\u662F\u600E\u4E48\u4E00\u9875\u9875\u5543\u5B8C\u5916\u6587\u539F\u7248\u4E66\u7684\uFF0C\u60F3\u8D77\u8305\u4EE5\u5347\u5148\u751F\u662F\u600E\u4E48\u8BF4\u201C\u594B\u6597\u201D\u7684\u2026\u2026"
  - "\u539F\u6765\u201C\u7AE2\u5B9E\u626C\u534E\u201D\u4E0D\u662F\u8981\u6211\u4EEC\u6025\u7740\u5F00\u82B1\u7ED3\u679C\uFF0C\u800C\u662F\u5148\u628A\u81EA\u5DF1\u7684\u6839\u624E\u6DF1\u4E00\u70B9\uFF0C\u518D\u6DF1\u4E00\u70B9"
  - "\u8BF6\uFF0C\u4F60\u4E5F\u5728\u8FD9\u513F\uFF1F"
  - "\u2014\u2014\u5750\u4E0B\u6765\u4F11\u606F\u4E00\u4E0B\uFF0C\u542C\u542C\u98CE\u8FC7\u68A7\u6850\u7684\u58F0\u97F3\u5427"
  repeatable: 1
  groupScript: {fileID: 0}
  isEasterEgg: 1
