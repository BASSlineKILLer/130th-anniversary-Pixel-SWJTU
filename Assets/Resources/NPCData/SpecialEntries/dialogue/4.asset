  scriptId: scence2_4_pt
  dialogueLines:
  - speakerName: "\u7F57\u8D74"
    text: "\u695A\u5BFC\uFF0C\u6211\u7238\u5988\u62C5\u5FC3\u571F\u6728\u592A\u82E6\uFF0C\u5973\u751F\u96BE\u575A\u6301\uFF0C\u975E\u8981\u6211\u8F6C\u4E13\u4E1A\uFF0C\u53EF\u6211\u771F\u60F3\u7559\u4E0B"
    portraitOverride: {fileID: 21300000, guid: a85abc78a9737f5499ae1a31d0fed0dd, type: 3}
  - speakerName: "\u695A\u8FB0\u6C85"
    text: "\u571F\u6728\u867D\u82E6\uFF0C\u5374\u80FD\u6253\u4E0B\u575A\u5B9E\u7684\u5DE5\u7A0B\u57FA\u7840\u3002\u5F53\u5E74\u6731\u9896\u5353\u5DE5\u7A0B\u5E08\u5728\u5510\u5C71\u4EA4\u5927\u6210\u5929\u62B1\u7740\u5916\u6587\u539F\u7248\u4E66\uFF0C\u5168\u82F1\u6587\u5543\u4E0B\u786C\u6838\u8BFE\u7A0B\uFF0C\u514B\u670D\u91CD\u91CD\u56F0\u96BE\u5B8C\u6210\u5B66\u4E1A\u3002\u4F60\u60F3\u4E00\u60F3\u6211\u4EEC\u7684\u6821\u8BAD\u662F\u4EC0\u4E48\uFF1F"
    portraitOverride: {fileID: 21300000, guid: a113575840088124787d276ef658ccd8, type: 3}
  - speakerName: "\u7F57\u8D74"
    text: "\u7AE2\u5B9E\u626C\u534E..."
    portraitOverride: {fileID: 21300000, guid: a85abc78a9737f5499ae1a31d0fed0dd, type: 3}
  - speakerName: "\u666F\u9038\u4E50"
    text: "\u81EA\u5F3A\u4E0D\u606F\uFF01\u7F57\u8D74\u4F60\u8FD9\u4E48\u806A\u660E\uFF0C\u6211\u89C9\u5F97\u4F60\u5B66\u571F\u6728\u80AF\u5B9A\u6CA1\u95EE\u9898\uFF0C\u5973\u751F\u5728\u4EA4\u5927\u5B66\u7406\u5DE5\u79D1\u5411\u6765\u90FD\u5F88\u51FA\u8272\uFF0C\u5BFC\u5458\u60A8\u8BF4\u662F\u5427\uFF1F"
    portraitOverride: {fileID: 21300000, guid: 8fe0c5790b384c6459b27cfdc8aac819, type: 3}
  - speakerName: "\u7F57\u8D74"
    text: "\u542C\u60A8\u8BB2\u4E86\u6731\u9896\u5353\u524D\u8F88\u7684\u4E8B\u8FF9\uFF0C\u6211\u6DF1\u53D7\u89E6\u52A8\u3002\u6211\u8981\u9075\u5FAA\u5185\u5FC3\u7EE7\u7EED\u5B66\u4E0B\u53BB\uFF01"
    portraitOverride: {fileID: 21300000, guid: a85abc78a9737f5499ae1a31d0fed0dd, type: 3}
  repeatable: 1
  medalNpcIds:
  - "\u7F57\u8D74"
