  m_Script: {fileID: 11500000, guid: ab4ff4b353bb91e48a7afeddfa77741a, type: 3}
  m_Name: 5
  m_EditorClassIdentifier: 
  scriptId: 
  dialogueLines:
  - speakerName: "\u7504\u96E8\u6850"
    text: "\u8001\u5E08\uFF0C\u592A\u9633\u592A\u6652\u4E86\uFF0C\u624B\u90FD\u6296\u4E86\uFF0C\u6570\u636E\u5DEE\r\n\u4E00\u70B9\u6CA1\u4E8B\u5427"
    portraitOverride: {fileID: 21300000, guid: 2c4606f9204f53d4f8502e59abbc820d, type: 3}
  - speakerName: "\u5F20\u654F"
    text: "\u5DEE\u4E00\u70B9\u90FD\u4E0D\u884C\u3002\u54B1\u4EEC\u4EA4\u5927\u8305\u4EE5\u5347\u5148\u751F\u5EFA\u94B1\r\n\u5858\u6C5F\u5927\u6865\u7684\u65F6\u5019\uFF0C\u52D8\u6D4B\u5DE5\u4F5C\u5206\u6BEB\u4E0D\u6562\u9A6C\u864E"
    portraitOverride: {fileID: 21300000, guid: 2474f47b4ad8eee4d85e0ce5bd98cbbe, type: 3}
  - speakerName: "\u5F20\u654F"
    text: "\u4ED6\u66FE\u8BF4\uFF1A\u201C\u4EBA\u751F\u4E00\u5F81\u9014\u8033\uFF0C\u5176\u957F\u767E\u5E74\uFF0C\u6211\r\n\u5DF2\u8D70\u8FC7\u5341\u4E4B\u4E03\u516B\u3002\u56DE\u9996\u524D\u5C18\uFF0C\u5386\u5386\u5728\u76EE\uFF0C\u5D0E\u5C96\u591A\r\n\u4E8E\u5E73\u5766\uFF0C\u5FFD\u6DF1\u8C37\uFF0C\u5FFD\u6D2A\u6D9B\uFF0C\u5E78\u8D56\u6865\u6881\u4EE5\u6E21\u3002\u6865\u4F55\r\n\u540D\u6B24\uFF1F\u65E5\u594B\u6597\u3002\u201D"
    portraitOverride: {fileID: 21300000, guid: 2474f47b4ad8eee4d85e0ce5bd98cbbe, type: 3}
  - speakerName: "\u4E8E\u80B2\u676D"
    text: "\u8305\u8001\u662F\u4EA4\u5927\u9A84\u50B2\uFF0C\u4E00\u751F\u5EFA\u6865\u62A5\u56FD\u3001\u6CBB\u5B66\r\n\u80B2\u4EBA\uFF0C\u662F\u6211\u4EEC\u6C38\u8FDC\u7684\u699C\u6837\uFF01"
    portraitOverride: {fileID: 21300000, guid: 3bd8c61182e9f784aaba595abae7d543, type: 3}
  - speakerName: "\u7504\u96E8\u6850"
    text: "\u6211\u61C2\u4E86\uFF0C\u6211\u4E00\u5B9A\u8BA4\u771F\u6D4B\u5B8C\u6BCF\u4E00\u7EC4\u6570\u636E\uFF01"
    portraitOverride: {fileID: 21300000, guid: 2474f47b4ad8eee4d85e0ce5bd98cbbe, type: 3}
  repeatable: 0
  medalNpcIds:
  - "\u4E8E\u80B2\u676D"
  - "\u7504\u96E8\u6850"
