  npcName: "\u56DE\u6BCD\u6821\u7684\u5B66\u59D0"
  worldSprite: {fileID: 21300000, guid: 23143509fef34ce4c94a7899c0407c31, type: 3}
  portrait: {fileID: 21300000, guid: 23143509fef34ce4c94a7899c0407c31, type: 3}
  dialogueLines:
  - "\uFF08\u8FDC\u8FDC\u770B\u89C1\u6807\u5FD7\u6027\u7684\u673A\u8F66\u535A\u7269\u9986\uFF09\u8FD9\u4E2A\u706B\u8F66\u5934\u8FD8\u5728\u554A\uFF0C\u4E00\u70B9\u6CA1\u53D8"
  - "\u4EE5\u524D\u6BD5\u4E1A\u7167\u5C31\u5728\u8FD9\u513F\u62CD\u7684\u3002"
  - "\u597D\u51E0\u5E74\u8FC7\u53BB\uFF0C\u65C1\u8FB9\u90A3\u68F5\u6811\u90FD\u957F\u9AD8\u4E86\u4E00\u622A"
  - "\u4E0D\u8FC7\u697C\u53D8\u591A\u53D8\u65B0\u4E86\uFF0C\u8001\u5546\u4E1A\u8857\u542C\u8BF4\u4E5F\u62C6\u4E86"
  - "\u4EA4\u5927\u7684\u57FA\u7840\u8BBE\u65BD\u4E00\u76F4\u5728\u53D8"
  - "\u53EF\u81EA\u5F3A\u4E0D\u606F\u3001\u7AE2\u5B9E\u626C\u534E\u7684\u7F8E\u597D\u6C1B\u56F4\u5374\u4E1D\u6BEB\u4E0D\u53D8\u554A"
