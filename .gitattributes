# Unity 大型二进制资产 - 使用 Git LFS 存储
# 字体文件
Assets/Fonts/*.asset filter=lfs diff=lfs merge=lfs -text
Assets/Fonts/*.ttf filter=lfs diff=lfs merge=lfs -text
Assets/Fonts/*.otf filter=lfs diff=lfs merge=lfs -text

# 图片/精灵
Assets/**/*.psd filter=lfs diff=lfs merge=lfs -text
Assets/**/*.png filter=lfs diff=lfs merge=lfs -text
Assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
Assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
Assets/**/*.tga filter=lfs diff=lfs merge=lfs -text
Assets/**/*.tiff filter=lfs diff=lfs merge=lfs -text

# 音频
Assets/**/*.wav filter=lfs diff=lfs merge=lfs -text
Assets/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
Assets/**/*.ogg filter=lfs diff=lfs merge=lfs -text
Assets/**/*.aif filter=lfs diff=lfs merge=lfs -text

# 视频
Assets/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
Assets/**/*.mov filter=lfs diff=lfs merge=lfs -text

# 3D 模型
Assets/**/*.fbx filter=lfs diff=lfs merge=lfs -text
Assets/**/*.obj filter=lfs diff=lfs merge=lfs -text

# Unity 包
*.unitypackage filter=lfs diff=lfs merge=lfs -text
